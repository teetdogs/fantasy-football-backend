NODE_ENV=development
PORT=3001

# PostgreSQL — use EITHER a connection string (cloud: Neon/Supabase/Render)
# OR the individual fields below (local). DATABASE_URL wins if set.
DATABASE_URL=
# Local fallback (ignored when DATABASE_URL is set):
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fantasy_football
DB_USER=postgres
DB_PASSWORD=password

# Google OAuth — get these from console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Session
SESSION_SECRET=change-this-to-a-random-string

# Frontend URL (for CORS + OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Season
SEASON=2026
